###############################################################################
#                        RAG SANDBOX — ENVIRONMENT FILE                       #
#                         March 2026 Docker Images                            #
#                                                                             #
#  Target: 10 GB RAM / 8 CPU server                                           #
#  Networks: rag-internal (all), rag-frontend (UI + NPM only)                 #
#  External ports: ONLY via Nginx Proxy Manager (80/443/8020)                 #
###############################################################################


# =============================================================================
# GENERAL SETTINGS
# =============================================================================
TZ=UTC
COMPOSE_PROJECT_NAME=rag-sandbox
RESTART_POLICY=unless-stopped


# =============================================================================
# LOGGING (applied to every container via x-logging anchor)
# =============================================================================
LOG_DRIVER=json-file
LOG_MAX_SIZE=50m
LOG_MAX_FILE=3


# =============================================================================
# RESOURCE LIMITS — 10 GB RAM / 8 CPU budget
# =============================================================================
# Defaults used by services that don't have a per-service override
DEFAULT_CPU_LIMIT=1.0
DEFAULT_MEM_LIMIT=512m

# --- Data layer ---
POSTGRES_CPU_LIMIT=2.0
POSTGRES_MEM_LIMIT=1536m

REDIS_CPU_LIMIT=0.5
REDIS_MEM_LIMIT=256m

QDRANT_CPU_LIMIT=1.0
QDRANT_MEM_LIMIT=1024m

NEO4J_CPU_LIMIT=1.0
NEO4J_MEM_LIMIT=1024m

MINIO_CPU_LIMIT=0.5
MINIO_MEM_LIMIT=256m

# --- AI / ML layer ---
OLLAMA_CPU_LIMIT=4.0
OLLAMA_MEM_LIMIT=3072m

EMBEDDING_CPU_LIMIT=2.0
EMBEDDING_MEM_LIMIT=1024m

RERANKER_CPU_LIMIT=1.0
RERANKER_MEM_LIMIT=768m

# --- Document processing ---
DOCLING_CPU_LIMIT=2.0
DOCLING_MEM_LIMIT=1024m

TIKA_CPU_LIMIT=1.0
TIKA_MEM_LIMIT=512m

UNSTRUCTURED_CPU_LIMIT=2.0
UNSTRUCTURED_MEM_LIMIT=1024m

# --- RAG engines ---
LIGHTRAG_CPU_LIMIT=1.0
LIGHTRAG_MEM_LIMIT=512m

MEM0_CPU_LIMIT=1.0
MEM0_MEM_LIMIT=512m

HINDSIGHT_CPU_LIMIT=1.0
HINDSIGHT_MEM_LIMIT=512m

RAGFLOW_CPU_LIMIT=2.0
RAGFLOW_MEM_LIMIT=1536m

# --- Platforms / UIs ---
DIFY_API_CPU_LIMIT=1.5
DIFY_API_MEM_LIMIT=768m

DIFY_WORKER_CPU_LIMIT=1.0
DIFY_WORKER_MEM_LIMIT=512m

DIFY_SANDBOX_CPU_LIMIT=0.5
DIFY_SANDBOX_MEM_LIMIT=256m

DIFY_WEB_CPU_LIMIT=0.5
DIFY_WEB_MEM_LIMIT=256m

OPENWEBUI_CPU_LIMIT=1.0
OPENWEBUI_MEM_LIMIT=512m

OPENWEBUI_PIPELINES_CPU_LIMIT=1.0
OPENWEBUI_PIPELINES_MEM_LIMIT=512m

ANYTHINGLLM_CPU_LIMIT=1.0
ANYTHINGLLM_MEM_LIMIT=512m

# --- Data management ---
NOCODB_CPU_LIMIT=0.5
NOCODB_MEM_LIMIT=256m

DIRECTUS_CPU_LIMIT=0.5
DIRECTUS_MEM_LIMIT=384m

TEABLE_CPU_LIMIT=0.5
TEABLE_MEM_LIMIT=384m

# --- Proxy ---
NPM_CPU_LIMIT=0.5
NPM_MEM_LIMIT=256m

NPM_DB_CPU_LIMIT=0.5
NPM_DB_MEM_LIMIT=256m

# --- Observability / tools ---
LITELLM_CPU_LIMIT=1.0
LITELLM_MEM_LIMIT=512m

LANGFUSE_CPU_LIMIT=1.0
LANGFUSE_MEM_LIMIT=512m

DBHUB_CPU_LIMIT=0.5
DBHUB_MEM_LIMIT=256m


# =============================================================================
# DOCKER IMAGES — March 2026
# =============================================================================
POSTGRES_IMAGE=pgvector/pgvector:pg17
REDIS_IMAGE=valkey/valkey:9.0.3-alpine
QDRANT_IMAGE=qdrant/qdrant:v1.16.3
NEO4J_IMAGE=neo4j:2026.02.3-community
MINIO_IMAGE=pgsty/minio:latest
INFINITY_IMAGE=michaelf34/infinity:latest
OLLAMA_IMAGE=ollama/ollama:latest
DOCLING_IMAGE=quay.io/ds4sd/docling-serve:latest
TIKA_IMAGE=apache/tika:latest-full
UNSTRUCTURED_IMAGE=downloads.unstructured.io/unstructured-io/unstructured:latest
LIGHTRAG_IMAGE=ghcr.io/hkuds/lightrag:latest
MEM0_IMAGE=mem0ai/mem0-server:latest
HINDSIGHT_IMAGE=ghcr.io/vectorize-io/hindsight:latest
RAGFLOW_IMAGE=infiniflow/ragflow:v0.24.0
DIFY_API_IMAGE=langgenius/dify-api:1.13.2
DIFY_WEB_IMAGE=langgenius/dify-web:1.13.2
DIFY_SANDBOX_IMAGE=langgenius/dify-sandbox:0.2.10
OPENWEBUI_IMAGE=ghcr.io/open-webui/open-webui:main
OPENWEBUI_PIPELINES_IMAGE=ghcr.io/open-webui/pipelines:main
ANYTHINGLLM_IMAGE=mintplexlabs/anythingllm:latest
NOCODB_IMAGE=nocodb/nocodb:latest
DIRECTUS_IMAGE=directus/directus:11.16
TEABLE_IMAGE=ghcr.io/teableio/teable:latest
NPM_IMAGE=jc21/nginx-proxy-manager:latest
NPM_DB_IMAGE=jc21/mariadb-aria:latest
LITELLM_IMAGE=ghcr.io/berriai/litellm:main-v1.82.3-stable
LANGFUSE_IMAGE=langfuse/langfuse:3
DBHUB_IMAGE=bytebase/dbhub:latest


# =============================================================================
# NETWORK NAMES
# =============================================================================
NETWORK_INTERNAL=rag-internal
NETWORK_FRONTEND=rag-frontend


# =============================================================================
# POSTGRESQL (pgvector/pgvector:pg17 — custom Dockerfile build)
# =============================================================================
POSTGRES_USER=ragadmin
POSTGRES_PASSWORD=Ch4ng3me_P0stgres!
POSTGRES_DB=ragdb
POSTGRES_PORT=5432
POSTGRES_LOCALE=ru_RU.UTF-8
POSTGRES_INITDB_ARGS=--locale=ru_RU.UTF-8 --encoding=UTF8

# Databases created by init.sql for individual services
POSTGRES_DB_RAGFLOW=ragflow
POSTGRES_DB_DIFY=dify
POSTGRES_DB_OPENWEBUI=openwebui
POSTGRES_DB_LIGHTRAG=lightrag
POSTGRES_DB_MEM0=mem0
POSTGRES_DB_HINDSIGHT=hindsight
POSTGRES_DB_DIRECTUS=directus
POSTGRES_DB_NOCODB=nocodb
POSTGRES_DB_TEABLE=teable
POSTGRES_DB_LANGFUSE=langfuse
POSTGRES_DB_LITELLM=litellm


# =============================================================================
# REDIS / VALKEY
# =============================================================================
REDIS_PASSWORD=Ch4ng3me_R3dis!
REDIS_PORT=6379
# Maximum memory Redis can use (fits within REDIS_MEM_LIMIT)
REDIS_MAXMEMORY=180mb
REDIS_MAXMEMORY_POLICY=allkeys-lru


# =============================================================================
# QDRANT — Vector Database
# =============================================================================
QDRANT_API_KEY=Ch4ng3me_Qdr4nt!
QDRANT_REST_PORT=6333
QDRANT_GRPC_PORT=6334
# Storage snapshot interval in seconds (0 = disabled)
QDRANT_SNAPSHOT_INTERVAL=3600


# =============================================================================
# NEO4J — Graph Database
# =============================================================================
NEO4J_USER=neo4j
NEO4J_PASSWORD=Ch4ng3me_Neo4j!
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_PLUGINS=["apoc","graph-data-science"]
NEO4J_HEAP_INITIAL=256m
NEO4J_HEAP_MAX=512m
NEO4J_PAGECACHE=256m
NEO4J_AUTH=neo4j/Ch4ng3me_Neo4j!


# =============================================================================
# MINIO — S3-compatible Object Storage
# =============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=Ch4ng3me_Min10!
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
# Default bucket created at startup
MINIO_DEFAULT_BUCKET=rag-documents


# =============================================================================
# INFINITY — Embedding Server
# =============================================================================
EMBED_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBED_PORT=7997
EMBED_BATCH_SIZE=32
# Engine: torch or optimum (ONNX)
EMBED_ENGINE=torch


# =============================================================================
# INFINITY — Reranker Server (same image, separate container)
# =============================================================================
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_PORT=7998
RERANK_ENGINE=torch


# =============================================================================
# OLLAMA — Local LLM Inference
# =============================================================================
OLLAMA_PORT=11434
OLLAMA_HOST=0.0.0.0
# Models to pull at first launch (comma-separated)
OLLAMA_MODELS=qwen3:14b,qwen3:1.7b
# Keep models loaded for 15 minutes
OLLAMA_KEEP_ALIVE=15m
OLLAMA_NUM_PARALLEL=2
OLLAMA_MAX_LOADED_MODELS=2


# =============================================================================
# DOCLING — Document Parsing Service
# =============================================================================
DOCLING_PORT=5001
DOCLING_WORKERS=2
DOCLING_MAX_PAGES=500


# =============================================================================
# APACHE TIKA — Document Extraction
# =============================================================================
TIKA_PORT=9998
# JVM memory for Tika (must fit within TIKA_MEM_LIMIT)
TIKA_JAVA_OPTS=-Xms128m -Xmx320m


# =============================================================================
# UNSTRUCTURED — Document Processing
# =============================================================================
UNSTRUCTURED_PORT=8000
UNSTRUCTURED_API_KEY=Ch4ng3me_Unstructured!


# =============================================================================
# LIGHTRAG — Graph-augmented RAG Engine
# =============================================================================
LIGHTRAG_PORT=9621
LIGHTRAG_LLM_BINDING=openai
LIGHTRAG_LLM_MODEL=qwen3:14b
LIGHTRAG_LLM_BINDING_HOST=http://ollama:11434/v1
LIGHTRAG_EMBEDDING_BINDING=openai
LIGHTRAG_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
LIGHTRAG_EMBEDDING_BINDING_HOST=http://embedding:7997/v1
LIGHTRAG_MAX_TOKENS=32768
LIGHTRAG_MAX_ASYNC=4
LIGHTRAG_CHUNK_SIZE=1200
LIGHTRAG_CHUNK_OVERLAP=100
LIGHTRAG_GRAPH_CLUSTER_ALGORITHM=leiden


# =============================================================================
# MEM0 — Semantic Memory Layer
# =============================================================================
MEM0_PORT=8888
MEM0_API_KEY=Ch4ng3me_M3m0!
MEM0_LLM_PROVIDER=ollama
MEM0_LLM_MODEL=qwen3:14b
MEM0_LLM_BASE_URL=http://ollama:11434
MEM0_EMBEDDING_PROVIDER=openai
MEM0_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
MEM0_EMBEDDING_BASE_URL=http://embedding:7997/v1
MEM0_VECTOR_STORE=qdrant
MEM0_QDRANT_HOST=qdrant
MEM0_QDRANT_PORT=6333


# =============================================================================
# HINDSIGHT — Agent Memory & Timeline
# =============================================================================
HINDSIGHT_API_PORT=8889
HINDSIGHT_UI_PORT=9999
HINDSIGHT_DB_URL=postgresql://ragadmin:Ch4ng3me_P0stgres!@postgres:5432/hindsight
HINDSIGHT_QDRANT_URL=http://qdrant:6333
HINDSIGHT_QDRANT_API_KEY=Ch4ng3me_Qdr4nt!


# =============================================================================
# RAGFLOW — RAG Platform
# =============================================================================
RAGFLOW_PORT=8021
RAGFLOW_API_PORT=8022
RAGFLOW_DB_HOST=postgres
RAGFLOW_DB_PORT=5432
RAGFLOW_DB_USER=ragadmin
RAGFLOW_DB_PASSWORD=Ch4ng3me_P0stgres!
RAGFLOW_DB_NAME=ragflow
RAGFLOW_REDIS_HOST=redis
RAGFLOW_REDIS_PORT=6379
RAGFLOW_REDIS_PASSWORD=Ch4ng3me_R3dis!
RAGFLOW_MINIO_HOST=minio
RAGFLOW_MINIO_PORT=9000
RAGFLOW_MINIO_USER=minioadmin
RAGFLOW_MINIO_PASSWORD=Ch4ng3me_Min10!


# =============================================================================
# DIFY — LLM Application Platform
# =============================================================================
# Shared secret key (min 32 chars)
DIFY_SECRET_KEY=Ch4ng3me_D1fy_Secret_32chars_min!

# -- Dify API (internal only; port 5001 is also used by Docling but no conflict
#    since Dify API port is container-internal and not host-mapped)
DIFY_API_PORT=5002
DIFY_MODE=api
DIFY_DB_HOST=postgres
DIFY_DB_PORT=5432
DIFY_DB_USER=ragadmin
DIFY_DB_PASSWORD=Ch4ng3me_P0stgres!
DIFY_DB_NAME=dify
DIFY_REDIS_HOST=redis
DIFY_REDIS_PORT=6379
DIFY_REDIS_PASSWORD=Ch4ng3me_R3dis!
DIFY_REDIS_DB=1
DIFY_CELERY_BROKER_URL=redis://:Ch4ng3me_R3dis!@redis:6379/2
DIFY_STORAGE_TYPE=s3
DIFY_S3_ENDPOINT=http://minio:9000
DIFY_S3_BUCKET=dify
DIFY_S3_ACCESS_KEY=minioadmin
DIFY_S3_SECRET_KEY=Ch4ng3me_Min10!
DIFY_S3_REGION=us-east-1

# -- Dify Worker --
DIFY_WORKER_MODE=worker

# -- Dify Sandbox --
DIFY_SANDBOX_PORT=8194
DIFY_SANDBOX_API_KEY=Ch4ng3me_D1fy_S4ndbox!
DIFY_SANDBOX_GIN_MODE=release

# -- Dify Web --
DIFY_WEB_PORT=8023
DIFY_WEB_API_URL=http://dify-api:5002/console/api
DIFY_WEB_APP_API_URL=http://dify-api:5002/api


# =============================================================================
# OPEN WEBUI — Chat Interface
# =============================================================================
OPENWEBUI_PORT=8024
OPENWEBUI_SECRET_KEY=Ch4ng3me_0penWebUI!
OPENWEBUI_OLLAMA_BASE_URL=http://ollama:11434
OPENWEBUI_WEBUI_AUTH=true
OPENWEBUI_DEFAULT_MODELS=qwen3:14b
OPENWEBUI_ENABLE_SIGNUP=true
OPENWEBUI_ENABLE_RAG_WEB_SEARCH=false
OPENWEBUI_DB_URL=postgresql://ragadmin:Ch4ng3me_P0stgres!@postgres:5432/openwebui


# =============================================================================
# OPEN WEBUI PIPELINES — Function Pipelines
# =============================================================================
OPENWEBUI_PIPELINES_PORT=9099
OPENWEBUI_PIPELINES_API_KEY=Ch4ng3me_P1pelines!


# =============================================================================
# ANYTHINGLLM — Document Workspace
# =============================================================================
ANYTHINGLLM_PORT=8025
ANYTHINGLLM_SERVER_PORT=3001
ANYTHINGLLM_JWT_SECRET=Ch4ng3me_4nyth1ng_JWT!
ANYTHINGLLM_LLM_PROVIDER=ollama
ANYTHINGLLM_OLLAMA_BASE_PATH=http://ollama:11434
ANYTHINGLLM_OLLAMA_MODEL_PREF=qwen3:14b
ANYTHINGLLM_EMBEDDING_ENGINE=generic-openai
ANYTHINGLLM_EMBEDDING_BASE_PATH=http://embedding:7997
ANYTHINGLLM_EMBEDDING_MODEL_PREF=Qwen/Qwen3-Embedding-0.6B
ANYTHINGLLM_VECTOR_DB=qdrant
ANYTHINGLLM_QDRANT_ENDPOINT=http://qdrant:6333
ANYTHINGLLM_QDRANT_API_KEY=Ch4ng3me_Qdr4nt!


# =============================================================================
# NOCODB — Airtable Alternative
# =============================================================================
NOCODB_PORT=8026
NC_DB=pg://postgres:5432?u=ragadmin&p=Ch4ng3me_P0stgres!&d=nocodb
NC_AUTH_JWT_SECRET=Ch4ng3me_N0coDB_JWT!
NC_PUBLIC_URL=http://localhost:8026


# =============================================================================
# DIRECTUS — Headless CMS
# =============================================================================
DIRECTUS_PORT=8027
DIRECTUS_KEY=Ch4ng3me_D1rectus_Key_Random!
DIRECTUS_SECRET=Ch4ng3me_D1rectus_Secret_Random!
DIRECTUS_DB_CLIENT=pg
DIRECTUS_DB_HOST=postgres
DIRECTUS_DB_PORT=5432
DIRECTUS_DB_DATABASE=directus
DIRECTUS_DB_USER=ragadmin
DIRECTUS_DB_PASSWORD=Ch4ng3me_P0stgres!
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=Ch4ng3me_D1rectus_Admin!
DIRECTUS_CACHE_ENABLED=true
DIRECTUS_CACHE_STORE=redis
DIRECTUS_REDIS=redis://:Ch4ng3me_R3dis!@redis:6379/3


# =============================================================================
# TEABLE — Spreadsheet Database
# =============================================================================
TEABLE_PORT=8028
TEABLE_DB_URL=postgresql://ragadmin:Ch4ng3me_P0stgres!@postgres:5432/teable
TEABLE_SECRET_KEY=Ch4ng3me_T3able_Secret!


# =============================================================================
# NGINX PROXY MANAGER — Reverse Proxy + SSL
# =============================================================================
NPM_HTTP_PORT=80
NPM_HTTPS_PORT=443
NPM_ADMIN_PORT=8020
NPM_DB_MYSQL_PASSWORD=Ch4ng3me_NPM_Mysql!
NPM_DB_MYSQL_DATABASE=npm
NPM_DB_MYSQL_USER=npm
NPM_DB_MYSQL_ROOT_PASSWORD=Ch4ng3me_NPM_Root!
# ⚠ SECURITY: First-login credentials — MUST be changed immediately after first login


# =============================================================================
# LITELLM — Unified LLM Proxy
# =============================================================================
LITELLM_PORT=4000
LITELLM_MASTER_KEY=sk-Ch4ng3me_L1teLLM_Master!
LITELLM_DB_URL=postgresql://ragadmin:Ch4ng3me_P0stgres!@postgres:5432/litellm
LITELLM_REDIS_HOST=redis
LITELLM_REDIS_PORT=6379
LITELLM_REDIS_PASSWORD=Ch4ng3me_R3dis!
LITELLM_LOG_LEVEL=INFO
LITELLM_REQUEST_TIMEOUT=120
LITELLM_NUM_RETRIES=3
# Langfuse integration for tracing
LITELLM_LANGFUSE_PUBLIC_KEY=pk-lf-change-me
LITELLM_LANGFUSE_SECRET_KEY=sk-lf-change-me
LITELLM_LANGFUSE_HOST=http://langfuse:3000


# =============================================================================
# LANGFUSE — LLM Observability & Tracing
# =============================================================================
LANGFUSE_PORT=3000
LANGFUSE_DATABASE_URL=postgresql://ragadmin:Ch4ng3me_P0stgres!@postgres:5432/langfuse
LANGFUSE_NEXTAUTH_SECRET=Ch4ng3me_Langfuse_NextAuth!
LANGFUSE_NEXTAUTH_URL=http://localhost:3000
LANGFUSE_SALT=Ch4ng3me_Langfuse_Salt_Random!
LANGFUSE_TELEMETRY_ENABLED=false
LANGFUSE_INIT_ORG_ID=rag-sandbox
LANGFUSE_INIT_ORG_NAME=RAG Sandbox
LANGFUSE_INIT_PROJECT_ID=default
LANGFUSE_INIT_PROJECT_NAME=Default Project
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-change-me
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-change-me
LANGFUSE_INIT_USER_EMAIL=admin@example.com
LANGFUSE_INIT_USER_PASSWORD=Ch4ng3me_Langfuse_Admin!
LANGFUSE_INIT_USER_NAME=Admin


# =============================================================================
# DBHUB — Database MCP Server
# =============================================================================
DBHUB_PORT=8033
DBHUB_DSN=postgresql://ragadmin:Ch4ng3me_P0stgres!@postgres:5432/ragdb


# =============================================================================
# EXTERNAL LLM API PROVIDERS (replace with real keys before use)
# =============================================================================

# OpenRouter — multi-model gateway
OPENROUTER_API_KEY=sk-or-v1-your_key_here
OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# Google Gemini
GEMINI_API_KEY=your_gemini_key_here

# Alibaba Qwen (DashScope)
QWEN_API_KEY=your_qwen_key_here
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# HuggingFace (model downloads & inference API)
HF_TOKEN=hf_your_token_here

# Moonshot Kimi
KIMI_API_KEY=your_kimi_key_here
KIMI_API_BASE=https://api.moonshot.cn/v1

# MiniMax
MINIMAX_API_KEY=your_minimax_key_here
MINIMAX_API_BASE=https://api.minimax.chat/v1


###############################################################################
#                              END OF .env FILE                               #
#                                                                             #
#  ⚠  SECURITY: Change all "Ch4ng3me_*" passwords before production use.     #
#  ⚠  API KEYS: Replace all placeholder keys with real values.               #
#  ⚠  Resource limits are tuned for a 10 GB / 8 CPU server — not all         #
#     services can run simultaneously at full allocation.                      #
###############################################################################
