###############################################################################
#                     RAG SANDBOX — ESSENTIAL VARIABLES                       #
#                                                                             #
#  Only the variables required for the stack to start.                        #
#  Copy this file to .env and fill in the values.                             #
#  For the full set of configurable options, see .env (the complete file).    #
###############################################################################

# --- Timezone ---
DOCKER_STACK_PREFIX=test
COMPOSE_PROJECT_NAME=rag-toolbox
RESTART_POLICY=unless-stopped
TZ=UTC

HF_TOKEN=
HF_ENDPOINT=

# --- PostgreSQL (REQUIRED — used by 11+ services) ---
POSTGRES_USER=ragadmin
POSTGRES_PASSWORD=CHANGE_ME_postgres_password
POSTGRES_DB=ragdb

# --- Per-service PostgreSQL credentials (REQUIRED — one user per database) ---
RAGFLOW_DB_USER=ragflow
RAGFLOW_DB_PASSWORD=CHANGE_ME_ragflow_db_password
DIFY_DB_USER=dify
DIFY_DB_PASSWORD=CHANGE_ME_dify_db_password
OPENWEBUI_DB_USER=openwebui
OPENWEBUI_DB_PASSWORD=CHANGE_ME_openwebui_db_password
LIGHTRAG_DB_USER=lightrag
LIGHTRAG_DB_PASSWORD=CHANGE_ME_lightrag_db_password
MEM0_DB_USER=mem0
MEM0_DB_PASSWORD=CHANGE_ME_mem0_db_password
HINDSIGHT_DB_USER=hindsight
HINDSIGHT_DB_PASSWORD=CHANGE_ME_hindsight_db_password
DIRECTUS_DB_USER=directus
DIRECTUS_DB_PASSWORD=CHANGE_ME_directus_db_password
NOCODB_DB_USER=nocodb
NOCODB_DB_PASSWORD=CHANGE_ME_nocodb_db_password
TEABLE_DB_USER=teable
TEABLE_DB_PASSWORD=CHANGE_ME_teable_db_password
LANGFUSE_DB_USER=langfuse
LANGFUSE_DB_PASSWORD=CHANGE_ME_langfuse_db_password
LITELLM_DB_USER=litellm
LITELLM_DB_PASSWORD=CHANGE_ME_litellm_db_password

# --- Redis / Valkey (REQUIRED — used by RAGFlow, Dify, LightRAG, etc.) ---
REDIS_PASSWORD=CHANGE_ME_redis_password

# --- Per-service Redis credentials (REQUIRED — one user per service) ---
RAGFLOW_REDIS_USER=ragflow
RAGFLOW_REDIS_PASSWORD=CHANGE_ME_ragflow_redis_password
DIFY_REDIS_USER=dify
DIFY_REDIS_PASSWORD=CHANGE_ME_dify_redis_password
LIGHTRAG_REDIS_USER=lightrag
LIGHTRAG_REDIS_PASSWORD=CHANGE_ME_lightrag_redis_password
DIRECTUS_REDIS_USER=directus
DIRECTUS_REDIS_PASSWORD=CHANGE_ME_directus_redis_password
NOCODB_REDIS_USER=nocodb
NOCODB_REDIS_PASSWORD=CHANGE_ME_nocodb_redis_password
TEABLE_REDIS_USER=teable
TEABLE_REDIS_PASSWORD=CHANGE_ME_teable_redis_password
LITELLM_REDIS_USER=litellm
LITELLM_REDIS_PASSWORD=CHANGE_ME_litellm_redis_password

# --- Qdrant (REQUIRED if using vector search services) ---
QDRANT_API_KEY=CHANGE_ME_qdrant_api_key

# --- Neo4j (REQUIRED if using GraphRAG / LightRAG / Mem0 graph) ---
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME_neo4j_password

# --- MinIO (REQUIRED if using RAGFlow, Dify, Directus, Teable) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password

# --- Dify (REQUIRED if running Dify) ---
DIFY_SECRET_KEY=CHANGE_ME_dify_secret_min_32_characters!!

# --- Open WebUI (REQUIRED if running Open WebUI) ---
OPENWEBUI_SECRET_KEY=CHANGE_ME_openwebui_secret

# --- AnythingLLM (REQUIRED if running AnythingLLM) ---
ANYTHINGLLM_JWT_SECRET=CHANGE_ME_anythingllm_jwt

# --- Nginx Proxy Manager MariaDB (REQUIRED if running NPM) ---
NPM_DB_MYSQL_PASSWORD=CHANGE_ME_npm_mysql
NPM_DB_MYSQL_ROOT_PASSWORD=CHANGE_ME_npm_root

# --- LiteLLM (REQUIRED if running LiteLLM) ---
LITELLM_MASTER_KEY=sk-CHANGE_ME_litellm_master_key

# --- Infinity API key (embedding + reranker servers and all callers) ---
INFINITY_API_KEY=CHANGE_ME_infinity_api_key

# --- Cloud LLM providers (REQUIRED to use cloud models) ---
OPENAI_API_KEY=CHANGE_ME_openai_key
ANTHROPIC_API_KEY=CHANGE_ME_anthropic_key
OLLAMA_API_KEY

# --- Langfuse (REQUIRED if running Langfuse) ---
LANGFUSE_NEXTAUTH_SECRET=CHANGE_ME_langfuse_nextauth
LANGFUSE_SALT=CHANGE_ME_langfuse_salt

# --- Directus (REQUIRED if running Directus) ---
DIRECTUS_SECRET=CHANGE_ME_directus_secret
DIRECTUS_KEY=CHANGE_ME_directus_key
DIRECTUS_ADMIN_PASSWORD=CHANGE_ME_directus_admin

# --- NocoDB (REQUIRED if running NocoDB) ---
NC_AUTH_JWT_SECRET=CHANGE_ME_nocodb_jwt

# --- Teable (REQUIRED if running Teable) ---
TEABLE_SECRET_KEY=CHANGE_ME_teable_secret

# --- SMTP (optional — email notifications) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=admin@example.com
ADMIN_EMAIL=admin@example.com
