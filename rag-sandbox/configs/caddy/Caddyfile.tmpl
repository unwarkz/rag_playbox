###############################################################################
#  Caddyfile.tmpl — RAG Sandbox Caddy reverse proxy (template)
#
#  This file is rendered at container start by docker-entrypoint.sh using
#  envsubst.  Do NOT use Caddy's own {$VAR} placeholders here — all
#  substitutions are handled by envsubst via ${VAR} syntax.
#
#  Default mode  (CADDY_HOST="", CADDY_TLS_MODE=off):
#    Every site listens on :{PORT} — plain HTTP, any incoming address.
#
#  Hostname + Let's Encrypt  (CADDY_HOST=example.com, CADDY_TLS_MODE=auto,
#                              CADDY_EMAIL=admin@example.com):
#    Every site listens on example.com:{PORT} — HTTPS via Let's Encrypt.
#    ⚠ Requires port 80 reachable from the internet (HTTP-01 ACME challenge).
#       If Nginx Proxy Manager already occupies port 80, use DNS-01 challenge
#       or CADDY_TLS_MODE=internal for local self-signed certificates.
#
#  TCP services (PostgreSQL, Redis, Qdrant gRPC, Neo4j Bolt):
#    Always bind to all interfaces on their port, regardless of CADDY_HOST.
#    They use Caddy's layer4 module for raw-TCP proxying.
###############################################################################

# =============================================================================
# GLOBAL OPTIONS
# =============================================================================
{
    ${CADDY_AUTO_HTTPS_DIRECTIVE}
    ${CADDY_EMAIL_DIRECTIVE}

    # -------------------------------------------------------------------------
    # TCP layer4 routes (raw TCP — PostgreSQL, Redis, Qdrant gRPC, Neo4j Bolt)
    # Always bind port-only (all interfaces) — no hostname matching for TCP.
    # -------------------------------------------------------------------------
    layer4 {

        # PostgreSQL — dev access (${CADDY_PORT_POSTGRES} → ${DOCKER_STACK_PREFIX}-postgres:${POSTGRES_PORT})
        :${CADDY_PORT_POSTGRES} {
            route {
                proxy {
                    upstream ${DOCKER_STACK_PREFIX}-postgres:${POSTGRES_PORT}
                }
            }
        }

        # Redis / Valkey — dev access (${CADDY_PORT_REDIS} → ${DOCKER_STACK_PREFIX}-redis:${REDIS_PORT})
        :${CADDY_PORT_REDIS} {
            route {
                proxy {
                    upstream ${DOCKER_STACK_PREFIX}-redis:${REDIS_PORT}
                }
            }
        }

        # Qdrant gRPC (${CADDY_PORT_QDRANT_GRPC} → ${DOCKER_STACK_PREFIX}-qdrant:${QDRANT_GRPC_PORT})
        :${CADDY_PORT_QDRANT_GRPC} {
            route {
                proxy {
                    upstream ${DOCKER_STACK_PREFIX}-qdrant:${QDRANT_GRPC_PORT}
                }
            }
        }

        # Neo4j Bolt driver protocol (${CADDY_PORT_NEO4J_BOLT} → ${DOCKER_STACK_PREFIX}-neo4j:${NEO4J_BOLT_PORT})
        :${CADDY_PORT_NEO4J_BOLT} {
            route {
                proxy {
                    upstream ${DOCKER_STACK_PREFIX}-neo4j:${NEO4J_BOLT_PORT}
                }
            }
        }

    }
}

# =============================================================================
# HTTP REVERSE PROXY ROUTES
#
# Site address: "${CADDY_HOST}:{PORT}"
#   CADDY_HOST="" (default) → :{PORT}   plain HTTP, any hostname/IP
#   CADDY_HOST=example.com  → example.com:{PORT}  TLS if CADDY_TLS_MODE=auto
# =============================================================================


# ---------------------------------------------------------------------------
# RAGFlow Web UI — port ${CADDY_PORT_RAGFLOW_WEB} → ${DOCKER_STACK_PREFIX}-ragflow:${RAGFLOW_HTTP_PORT}
# ---------------------------------------------------------------------------
${CADDY_HOST}:${CADDY_PORT_RAGFLOW_WEB} {
    ${CADDY_TLS_DIRECTIVE}
    reverse_proxy ${DOCKER_STACK_PREFIX}-ragflow:${RAGFLOW_HTTP_PORT}
}

