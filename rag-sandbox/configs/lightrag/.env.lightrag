# =============================================================================
# LightRAG extended configuration
# =============================================================================

# LLM concurrency and token limits
LIGHTRAG_LLM_MAX_ASYNC=4
LIGHTRAG_LLM_MAX_TOKEN=32768

# Enable LLM response caching to reduce duplicate API calls
ENABLE_LLM_CACHE=true

# Chunking parameters
CHUNK_SIZE=1200
CHUNK_OVERLAP_TOKEN_SIZE=100

# Knowledge graph context limits
MAX_GRAPH_NODES_IN_CONTEXT=2000

# Graph clustering algorithm (leiden provides good community detection)
GRAPH_CLUSTER_ALGORITHM=leiden
