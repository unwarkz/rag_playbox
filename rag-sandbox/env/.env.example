    image: ${POSTGRES_IMAGE}
    env_file:
      - env/general.env
      - env/docker.env
      - env/postgres.env

  redis:
    image: ${REDIS_IMAGE}
    env_file:
      - env/general.env
      - env/docker.env
      - env/redis.env

  qdrant:
    image: ${QDRANT_IMAGE}
    env_file:
      - env/general.env
      - env/docker.env
      - env/qdrant.env

  minio:
    image: ${MINIO_IMAGE}
    env_file:
      - env/general.env
      - env/docker.env
      - env/minio.env

  ollama:
    image: ${OLLAMA_IMAGE}
    env_file:
