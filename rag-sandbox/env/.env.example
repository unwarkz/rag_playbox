      - env/ragflow.env


# EXAMPLE 3: Development Setup
# =============================
# Fewer resource limits, optional services only

services:
  postgres:
    image: ${POSTGRES_IMAGE}
    env_file:
      - env/general.env
      - env/docker.env
      - env/postgres.env
      - env/email.env

  redis:
    image: ${REDIS_IMAGE}
    env_file:
      - env/general.env
      - env/docker.env
      - env/redis.env

  ollama:
    image: ${OLLAMA_IMAGE}
    env_file:
      - env/general.env
      - env/docker.env
      - env/ollama.env

  openwebui:
    image: ${OPENWEBUI_IMAGE}
    env_file:
      - env/general.env
      - env/docker.env
      - env/openwebui.env
      - env/api-keys.env


# EXAMPLE 4: Observability Stack
# ================================
# Monitoring: LiteLLM + Langfuse + Database

services:
  postgres:
    image: ${POSTGRES_IMAGE}
    env_file:
      - env/general.env
      - env/docker.env
      - env/postgres.env

  redis:
    image: ${REDIS_IMAGE}
    env_file:
      - env/general.env
      - env/docker.env
      - env/redis.env

  litellm:
    image: ${LITELLM_IMAGE}
    env_file:
      - env/general.env
      - env/docker.env
      - env/litellm.env
      - env/api-keys.env

  langfuse:
    image: ${LANGFUSE_IMAGE}
    env_file:
      - env/general.env
      - env/docker.env
      - env/langfuse.env
      - env/email.env

  dbhub:
    image: ${DBHUB_IMAGE}
    env_file:
      - env/general.env
      - env/docker.env
      - env/dbhub.env


# ENVIRONMENT VARIABLE LOADING ORDER
# ====================================
#
# When using multiple env_file entries, variables are loaded in order.
# Later files overwrite earlier ones. Recommended load order:
#
#   1. env/general.env          (base settings: TZ, project name)
#   2. env/docker.env           (Docker config: limits, images, networks)
#   3. env/{service}.env        (service-specific: credentials, ports)
#   4. env/email.env            (if needed: SMTP)
#   5. env/api-keys.env         (if needed: external providers)
#   6. env/host-ports.env       (if needed: dev SSH tunnels)
#
# This order ensures:
#   • Base settings applied first
#   • Resource limits won't be overwritten
#   • Service overrides come last
#   • Optional security files added as needed


# SHARED ENVIRONMENT VARIABLES
# =============================
#
# Variables used by multiple services are defined in:
#
#   • general.env:     TZ, COMPOSE_PROJECT_NAME
#   • docker.env:      RESTART_POLICY, LOG_*, NETWORK_*, RESOURCE LIMITS, *_IMAGE, *_CPU_LIMIT, *_MEM_LIMIT
#   • email.env:       SMTP_*, ADMIN_EMAIL (loaded by: Dify, Directus, Langfuse, Teable, etc.)
#   • api-keys.env:    OPENAI_API_KEY, ANTHROPIC_API_KEY, etc. (loaded by: Dify, LiteLLM, etc.)
#
# Per-service files contain ONLY that service's config to avoid conflicts.


# MEMORY/CPU ALLOCATION TABLE
# ============================
#
# Service                CPU        Memory    File
# ─────────────────────────────────────────────────
# PostgreSQL            2.0 CPU    1536 MB   postgres.env
# Redis/Valkey          0.5 CPU     256 MB   redis.env
# Qdrant                1.0 CPU    1024 MB   qdrant.env
# Neo4j                 1.0 CPU    1024 MB   neo4j.env
# MinIO                 0.5 CPU     256 MB   minio.env
# Ollama                4.0 CPU    3072 MB   ollama.env
# Embedding (Infinity)  2.0 CPU    1024 MB   infinity.env
# Reranker (Infinity)   1.0 CPU     768 MB   infinity.env
# Docling               2.0 CPU    1024 MB   docling.env
# Repository             1.0 CPU    1024 MB   ragflow.env
# Dify API              1.5 CPU     768 MB   dify.env
# Open WebUI            1.0 CPU     512 MB   openwebui.env
# ─────────────────────────────────────────────────
# TOTAL (if all run)   ≈21.5 CPU  ≈16 GB
#
# Note: Limits set for 10 GB / 8 CPU server → select services carefully
#       See docker.env for per-service CPU/memory limits


###############################################################################
#                    QUICK START COMMANDS
###############################################################################

# 1. Start specific docker-compose with split env files:
#    docker-compose -f docker-compose-full.yml up -d

# 2. Check which services are running:
#    docker-compose ps

# 3. View logs from a specific service:
#    docker-compose logs -f ragflow

# 4. Access services (after startup):
#    • Open WebUI:      http://localhost:8024
#    • Dify:            http://localhost:8023
#    • RAGFlow:         http://localhost:8021
#    • Nginx Proxy:     http://localhost:8020 (admin panel)
#    • LiteLLM:         http://localhost:4000
#    • Langfuse:        http://localhost:3000

# 5. Stop everything:
#    docker-compose down

# 6. View environment variables in a running container:
#    docker exec <container_id> env | sort

###############################################################################
