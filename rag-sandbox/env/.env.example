###############################################################################
#                DOCKER-COMPOSE ENV_FILE USAGE EXAMPLES
#                          .env.example
###############################################################################

# This file shows how to integrate the split .env files into your 
# docker-compose.yml configuration.


# EXAMPLE 1: Full Stack Configuration
# ====================================
# Use in docker-compose-full.yml or similar

services:
  postgres:
    image: ${POSTGRES_IMAGE}
    env_file:
      - env/general.env
      - env/docker.env
      - env/postgres.env
      - env/email.env
    # ... rest of service config

  redis:
    image: ${REDIS_IMAGE}
    env_file:
      - env/general.env
      - env/docker.env
      - env/redis.env
    # ... rest of service config

  qdrant:
    image: ${QDRANT_IMAGE}
    env_file:
      - env/general.env
      - env/docker.env
      - env/qdrant.env
    # ... rest of service config

  neo4j:
    image: ${NEO4J_IMAGE}
    env_file:
      - env/general.env
      - env/docker.env
      - env/neo4j.env
    # ... rest of service config

  minio:
    image: ${MINIO_IMAGE}
    env_file:
      - env/general.env
      - env/docker.env
      - env/minio.env
    # ... rest of service config

  embedding:
    image: ${INFINITY_IMAGE}
    env_file:
      - env/general.env
      - env/docker.env
      - env/infinity.env
    # ... rest of service config

  ollama:
    image: ${OLLAMA_IMAGE}
    env_file:
      - env/general.env
      - env/docker.env
      - env/ollama.env
    # ... rest of service config

  ragflow:
    image: ${RAGFLOW_IMAGE}
    env_file:
      - env/general.env
      - env/docker.env
      - env/ragflow.env
      - env/email.env
    # ... rest of service config

  dify-api:
    image: ${DIFY_API_IMAGE}
    env_file:
      - env/general.env
      - env/docker.env
      - env/dify.env
      - env/email.env
      - env/api-keys.env
    # ... rest of service config

  openwebui:
    image: ${OPENWEBUI_IMAGE}
    env_file:
      - env/general.env
      - env/docker.env
      - env/openwebui.env
      - env/email.env
      - env/api-keys.env
    # ... rest of service config


# EXAMPLE 2: Minimal RAG Stack
# =============================
# Use only essential services without heavy platforms

