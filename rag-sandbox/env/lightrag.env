###############################################################################
#     LIGHTRAG - Graph-augmented RAG Engine
#      (ghcr.io/hkuds/lightrag:latest)
###############################################################################

# --- Port ---
LIGHTRAG_PORT=9621

# --- LLM Configuration ---
LIGHTRAG_LLM_BINDING=openai
LIGHTRAG_LLM_MODEL=qwen3:14b
LIGHTRAG_LLM_BINDING_HOST=http://ollama:11434/v1

# --- Embedding Configuration ---
LIGHTRAG_EMBEDDING_BINDING=openai
LIGHTRAG_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
LIGHTRAG_EMBEDDING_BINDING_HOST=http://embedding:7997/v1

# --- Processing ---
LIGHTRAG_MAX_TOKENS=32768
LIGHTRAG_MAX_ASYNC=4
LIGHTRAG_CHUNK_SIZE=1200
LIGHTRAG_CHUNK_OVERLAP=100
LIGHTRAG_GRAPH_CLUSTER_ALGORITHM=leiden

# --- Storage Configuration ---
LIGHTRAG_KV_STORAGE=PGKVStorage
LIGHTRAG_DOC_STATUS_STORAGE=PGDocStatusStorage
LIGHTRAG_VECTOR_STORAGE=QdrantVectorDBStorage
LIGHTRAG_GRAPH_STORAGE=Neo4JStorage

# --- Redis Connection ---
LIGHTRAG_REDIS_URI=redis://lightrag:Ch4ng3me_L1ghtRAG_redis!@redis:6379/3
