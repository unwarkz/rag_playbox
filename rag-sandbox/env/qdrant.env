# --- Security ---
QDRANT_API_KEY=Ch4ng3me_Qdr4nt!

# --- Ports ---
QDRANT_REST_PORT=6333
QDRANT_GRPC_PORT=6334

# --- Configuration ---
# Storage snapshot interval in seconds (0 = disabled)
QDRANT_SNAPSHOT_INTERVAL=3600
# Enable the web dashboard at /dashboard (true by default; set false to disable)
# When QDRANT_API_KEY is set the dashboard shows an API-key login prompt on
# first visit; the key is stored in browser localStorage for subsequent visits.
# Via Caddy (port 8039) the key is injected automatically — no login needed.
QDRANT_STATIC_CONTENT=true
