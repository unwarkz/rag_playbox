# --- Port ---
LANGFUSE_PORT=3000

# --- Database Connection ---
LANGFUSE_DATABASE_URL=postgresql://langfuse:Ch4ng3me_L4ngfuse_db!@postgres:5432/langfuse

# --- Security & Authentication ---
