###############################################################################
#        OLLAMA - Local LLM Inference (ollama:latest)
###############################################################################

# =============================================================================
# PORT & HOST CONFIGURATION
# =============================================================================
OLLAMA_PORT=11434
OLLAMA_HOST=0.0.0.0:11434

# Allowed origins for CORS (comma-separated list)
OLLAMA_ORIGINS=*


# =============================================================================
# MODEL MANAGEMENT
# =============================================================================
# Models to pull at first launch (comma-separated)
OLLAMA_MODELS=qwen3:14b,qwen3:1.7b

# Path to models directory (leave empty for default ~/.ollama/models)
OLLAMA_MODELS_PATH=

# How long to allow model loads to stall before giving up
OLLAMA_LOAD_TIMEOUT=5m

# Do not preserve model history
OLLAMA_NOHISTORY=false

# Do not prune model blobs on startup
OLLAMA_NOPRUNE=false


# =============================================================================
# PERFORMANCE & RESOURCES
# =============================================================================
# Keep models loaded for specified duration (0 = always load, -1 = never unload)
OLLAMA_KEEP_ALIVE=15m

# Maximum number of concurrent requests per model
OLLAMA_NUM_PARALLEL=2

# Maximum number of models to keep loaded in memory simultaneously
OLLAMA_MAX_LOADED_MODELS=2

# Maximum number of queued requests
OLLAMA_MAX_QUEUE=

# Reserve a portion of VRAM per GPU (in bytes) - GPU only
OLLAMA_GPU_OVERHEAD=


# =============================================================================
# ATTENTION & CACHE OPTIMIZATION
# =============================================================================
# Enable flash attention for faster inference
OLLAMA_FLASH_ATTENTION=false

# Quantization type for K/V cache (options: f16, q8, q4)
OLLAMA_KV_CACHE_TYPE=f16

# Context length to use unless otherwise specified 
# (default: 4k/32k/256k based on VRAM)
OLLAMA_CONTEXT_LENGTH=

# Optimize prompt caching for multi-user scenarios
OLLAMA_MULTIUSER_CACHE=false


# =============================================================================
# SCHEDULING & DISTRIBUTION
# =============================================================================
# Always schedule model across all GPUs (GPU only)
OLLAMA_SCHED_SPREAD=false


# =============================================================================
# INFERENCE ENGINE
# =============================================================================
# Set LLM library to bypass autodetection (e.g., "cpu", "cuda", "rocm")
OLLAMA_LLM_LIBRARY=

# Enable the new Ollama engine (experimental)
OLLAMA_NEW_ENGINE=false


# =============================================================================
# CLOUD & REMOTE FEATURES
# =============================================================================
# Disable Ollama cloud features (remote inference and web search)
OLLAMA_NO_CLOUD=false

# Allowed hosts for remote models (default: "ollama.com")
OLLAMA_REMOTES=


# =============================================================================
# DEBUGGING
# =============================================================================
# Show additional debug information (set to 1 to enable)
OLLAMA_DEBUG=0

# Log inference request bodies and replay curl commands to temp directory
OLLAMA_DEBUG_LOG_REQUESTS=false


# =============================================================================
# INTERACTIVE FEATURES
# =============================================================================
# Path to editor for interactive prompt editing (Ctrl+G in CLI)
OLLAMA_EDITOR=


# =============================================================================
# API AUTHENTICATION (Optional)
# =============================================================================
# Bearer token for API authentication (leave empty to disable)
OLLAMA_API_TOKEN=
