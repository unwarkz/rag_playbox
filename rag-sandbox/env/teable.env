###############################################################################
#      TEABLE - Spreadsheet Database
#      (ghcr.io/teableio/teable:latest)
###############################################################################

# --- Port (used by Nginx Proxy Manager for routing) ---
TEABLE_PORT=8028

# --- Public access URL (REQUIRED — set to your accessible Teable address) ---
# PUBLIC_ORIGIN=http://your-server-ip:3000

# --- Database Connection ---
# Auto-constructed from per-service credentials (see postgres.env).
# Override the full URL here only if connecting to an external database:
# TEABLE_DB_URL=postgresql://teable:<password>@postgres:5432/teable

# --- Security ---
TEABLE_SECRET_KEY=Ch4ng3me_T3able_Secret!

# --- Storage (MinIO S3-compatible) ---
TEABLE_STORAGE_PROVIDER=minio
# Buckets must be pre-created in MinIO before starting:
#   teable-public  — set with public read access (avatars, form headers)
#   teable-private — private bucket (attachment content)
TEABLE_PUBLIC_BUCKET=teable-public
TEABLE_PRIVATE_BUCKET=teable-private
# Internal endpoint: Docker-internal hostname for server-side MinIO API calls
TEABLE_MINIO_INTERNAL_ENDPOINT=minio
# Public endpoint host: used to construct browser-accessible file URLs.
# Set to your server IP or domain name for production deployments.
TEABLE_MINIO_ENDPOINT=minio
TEABLE_STORAGE_MINIO_USE_SSL=false
# STORAGE_PREFIX: base URL embedded in generated file links (must reach MinIO from browsers).
# For local dev: http://localhost:9000 (requires MinIO port 9000 to be mapped to host).
# For production: https://minio.yourdomain.com (via Nginx Proxy Manager or public IP).
TEABLE_STORAGE_PREFIX=http://localhost:9000

# --- Caching (Redis db:7) ---
TEABLE_CACHE_PROVIDER=redis
TEABLE_REDIS_DB=7
TEABLE_REDIS_URI=redis://teable:Ch4ng3me_T3able_redis!@redis:6379/7

# --- Optional: External database proxy ---
# Allows external clients (e.g. psql, TablePlus) to connect to the Teable database.
# Set to host:port where the DB proxy should be reachable (e.g. your-server-ip:42345).
# PUBLIC_DATABASE_PROXY=your-server-ip:42345

# --- Optional: Performance cache (separate Redis instance recommended) ---
# Caches query results for improved multi-user collaboration efficiency.
# BACKEND_PERFORMANCE_CACHE=redis://teable:Ch4ng3me_T3able_redis!@redis:6379/7
