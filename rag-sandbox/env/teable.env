###############################################################################
#      TEABLE - Spreadsheet Database
#      (ghcr.io/teableio/teable:latest)
###############################################################################

# --- Port ---
TEABLE_PORT=8028

# --- Database Connection ---
TEABLE_DB_URL=postgresql://teable:Ch4ng3me_T3able_db!@postgres:5432/teable

# --- Security ---
TEABLE_SECRET_KEY=Ch4ng3me_T3able_Secret!

# --- Storage (MinIO) ---
TEABLE_STORAGE_PROVIDER=minio
TEABLE_STORAGE_MINIO_USE_SSL=false

# --- Caching (Redis) ---
TEABLE_CACHE_PROVIDER=redis
TEABLE_REDIS_URI=redis://teable:Ch4ng3me_T3able_redis!@redis:6379/7

# --- Email ---
TEABLE_MAIL_SENDER_NAME=Teable
