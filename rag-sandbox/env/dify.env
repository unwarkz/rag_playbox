###############################################################################
#      DIFY - LLM Application Platform
#      (langgenius/dify-api:1.13.2, dify-web:1.13.2, etc.)
###############################################################################

# --- Security ---
# Shared secret key (min 32 chars)
DIFY_SECRET_KEY=Ch4ng3me_D1fy_Secret_32chars_min!


# --- DIFY API ---
DIFY_MODE=api
DIFY_API_PORT=5001

# Database Connection
DIFY_DB_HOST=postgres
DIFY_DB_PORT=5432
DIFY_DB_NAME=dify
DIFY_DB_USER=dify
DIFY_DB_PASSWORD=Ch4ng3me_D1fy_db!

# Redis Connection
DIFY_REDIS_HOST=redis
DIFY_REDIS_PORT=6379
DIFY_REDIS_PASSWORD=Ch4ng3me_D1fy_redis!
DIFY_REDIS_DB=1

# Celery Broker
DIFY_CELERY_BROKER_URL=redis://dify:Ch4ng3me_D1fy_redis!@redis:6379/2

# S3 Storage (MinIO)
DIFY_STORAGE_TYPE=s3
DIFY_S3_ENDPOINT=http://minio:9000
DIFY_S3_BUCKET=dify
DIFY_S3_ACCESS_KEY=minioadmin
DIFY_S3_SECRET_KEY=Ch4ng3me_Min10!
DIFY_S3_REGION=us-east-1

# Vector Store
DIFY_VECTOR_STORE=qdrant

# Email Configuration
DIFY_MAIL_TYPE=smtp

# Code Execution
DIFY_CODE_EXECUTION_ENDPOINT=http://dify-sandbox:8194


# --- DIFY WORKER ---
DIFY_WORKER_MODE=worker


# --- DIFY SANDBOX ---
DIFY_SANDBOX_PORT=8194
DIFY_SANDBOX_API_KEY=Ch4ng3me_D1fy_S4ndbox!
DIFY_SANDBOX_GIN_MODE=release


# --- DIFY WEB UI ---
DIFY_WEB_PORT=8023
DIFY_WEB_API_URL=http://dify-api:5001/console/api
DIFY_WEB_APP_API_URL=http://dify-api:5001/api
