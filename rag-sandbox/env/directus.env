###############################################################################
#      DIRECTUS - Headless CMS & Data Platform
#      (directus/directus:11.16)
###############################################################################

# --- Port ---
DIRECTUS_PORT=8027

# --- Security ---
DIRECTUS_KEY=Ch4ng3me_D1rectus_Key_Random!
DIRECTUS_SECRET=Ch4ng3me_D1rectus_Secret_Random!

# --- Database Connection ---
DIRECTUS_DB_CLIENT=pg
DIRECTUS_DB_HOST=postgres
DIRECTUS_DB_PORT=5432
DIRECTUS_DB_DATABASE=directus
DIRECTUS_DB_USER=directus
DIRECTUS_DB_PASSWORD=Ch4ng3me_D1rectus_db!

# --- Admin Account ---
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=Ch4ng3me_D1rectus_Admin!

# --- Caching ---
DIRECTUS_CACHE_ENABLED=true
DIRECTUS_CACHE_STORE=redis
DIRECTUS_REDIS=redis://directus:Ch4ng3me_D1rectus_redis!@redis:6379/4

# --- Email ---
DIRECTUS_EMAIL_TRANSPORT=smtp

# --- Storage (S3)
DIRECTUS_STORAGE_LOCATIONS=s3
DIRECTUS_STORAGE_S3_DRIVER=s3
DIRECTUS_STORAGE_S3_REGION=us-east-1
DIRECTUS_STORAGE_S3_FORCE_PATH_STYLE=true
