# --- Port ---
LITELLM_PORT=4000

# --- Security ---
LITELLM_MASTER_KEY=sk-Ch4ng3me_L1teLLM_Master!

# --- Database Connection ---
LITELLM_DB_URL=postgresql://litellm:Ch4ng3me_L1teLLM_db!@postgres:5432/litellm

# --- Redis Cache ---
