# --- Nginx Ports ---
NPM_HTTP_PORT=80
NPM_HTTPS_PORT=443
NPM_ADMIN_PORT=8020

# --- NPM Database (MariaDB) ---
NPM_DB_MYSQL_USER=npm
NPM_DB_MYSQL_PASSWORD=Ch4ng3me_NPM_Mysql!
NPM_DB_MYSQL_ROOT_PASSWORD=Ch4ng3me_NPM_Root!
NPM_DB_MYSQL_DATABASE=npm

# ⚠ SECURITY: First-login credentials — MUST be changed immediately after first login
# Default: admin@example.com / changeme
