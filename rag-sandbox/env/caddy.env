###############################################################################
#  env/caddy.env — Caddy reverse-proxy configuration
#
#  All variables have defaults that produce plain HTTP on ports 8021–8044.
#  Edit this file to:
#    • re-map a port              — change CADDY_PORT_<SERVICE>=<new port>
#    • disable a service proxy   — NOT possible per-service; remove from
#                                  Caddyfile.tmpl if needed
#    • set a custom hostname      — set CADDY_HOST=yourdomain.com
#    • enable Let's Encrypt TLS   — see the TLS section below
#
#  ⚠  After changing any value, restart the caddy service:
#       docker compose ... restart caddy
###############################################################################


# =============================================================================
# SERVICE AUTH TOKENS
#
#   Mirror values from the matching service env file so Caddy can enforce
#   authentication at the proxy layer.  Leave a variable empty to disable
#   proxy-level auth for that service.
#
#   OLLAMA_BEARER_TOKEN — enforced on port 8036 (Ollama external proxy port).
#     Clients must send:  Authorization: Bearer <token>
#     Internal services that call ollama:11434 directly are NOT affected.
#     Set the same value as env/ollama.env → OLLAMA_BEARER_TOKEN.
#
#   QDRANT_API_KEY — injected by Caddy as Authorization: Bearer on every
#     request to Qdrant (port 8039).  The dashboard at /dashboard will open
#     without requiring the user to enter the key manually.
#     Set the same value as env/qdrant.env → QDRANT_API_KEY.
# =============================================================================
OLLAMA_BEARER_TOKEN=
QDRANT_API_KEY=


# =============================================================================
# HOST BINDING
#
#   CADDY_HOST=""            (default) — listen on :{PORT}, any address/host
#   CADDY_HOST=example.com   — listen on example.com:{PORT} (for TLS / named vhosts)
# =============================================================================
CADDY_HOST=


# =============================================================================
# TLS MODE
#
#   off        (default) — plain HTTP, no certificates
#   auto       — Let's Encrypt ACME (requires CADDY_HOST + CADDY_EMAIL, and
#                port 80/443 accessible from the internet for HTTP-01 challenge)
#   internal   — Caddy self-signed internal CA (local HTTPS testing, no internet)
# =============================================================================
CADDY_TLS_MODE=off

# Email address for Let's Encrypt account registration (required when CADDY_TLS_MODE=auto)
CADDY_EMAIL=


# =============================================================================
# EXTERNAL PORT MAPPINGS  (host port → Caddy → internal service)
#
#   Change any value to remap the external port.
#   Set to the same value as the default if no change is needed.
# =============================================================================

# --- AI / RAG UIs ---
CADDY_PORT_RAGFLOW_WEB=8021       # RAGFlow Web UI         → ragflow:9380
CADDY_PORT_RAGFLOW_API=8022       # RAGFlow REST API        → ragflow:9380
CADDY_PORT_DIFY=8023              # Dify LLM builder        → dify-web:3000
CADDY_PORT_OPENWEBUI=8024         # Open WebUI chat         → openwebui:8080
CADDY_PORT_ANYTHINGLLM=8025       # AnythingLLM workspace   → anythingllm:3001
CADDY_PORT_NOCODB=8026            # NocoDB no-code table    → nocodb:8080
CADDY_PORT_DIRECTUS=8027          # Directus headless CMS   → directus:8055
CADDY_PORT_TEABLE=8028            # Teable spreadsheet      → teable:3000
CADDY_PORT_LIGHTRAG=8029          # LightRAG GraphRAG       → lightrag:9621
CADDY_PORT_HINDSIGHT_UI=8030      # Hindsight memory UI     → hindsight:9999
CADDY_PORT_HINDSIGHT_API=8031     # Hindsight memory API    → hindsight:8889
CADDY_PORT_MEM0=8032              # Mem0 agent memory API   → mem0:8888
CADDY_PORT_DOCLING=8033           # Docling document parser → docling:5001
CADDY_PORT_EMBEDDING=8034         # Infinity embedding      → embedding:7997
CADDY_PORT_RERANKER=8035          # Infinity reranker       → reranker:7998
CADDY_PORT_OLLAMA=8036            # Ollama LLM server       → ollama:11434

# --- Infrastructure (dev/direct access) ---
CADDY_PORT_POSTGRES=8037          # PostgreSQL              → postgres:5432   [TCP]
CADDY_PORT_REDIS=8038             # Redis / Valkey cache    → redis:6379      [TCP]
CADDY_PORT_QDRANT_REST=8039       # Qdrant REST API         → qdrant:6333
CADDY_PORT_QDRANT_GRPC=8040       # Qdrant gRPC             → qdrant:6334     [TCP]
CADDY_PORT_NEO4J_HTTP=8041        # Neo4j HTTP browser      → neo4j:7474
CADDY_PORT_NEO4J_BOLT=8042        # Neo4j Bolt driver       → neo4j:7687      [TCP]
CADDY_PORT_MINIO_API=8043         # MinIO S3 API            → minio:9000
CADDY_PORT_MINIO_CONSOLE=8044     # MinIO Console UI        → minio:9001
