###############################################################################
#                        DOCKER SETTINGS
###############################################################################

# =============================================================================
# RESTART POLICY
# =============================================================================
RESTART_POLICY=unless-stopped


# =============================================================================
# LOGGING (applied to every container via x-logging anchor)
# =============================================================================
LOG_DRIVER=json-file
LOG_MAX_SIZE=50m
LOG_MAX_FILE=3
LOG_LEVEL=INFO


# =============================================================================
# NETWORK NAMES
# =============================================================================
NETWORK_INTERNAL=rag-internal
NETWORK_FRONTEND=rag-frontend


# =============================================================================
# RESOURCE LIMITS — 10 GB RAM / 8 CPU budget
# =============================================================================
# Defaults used by services that don't have a per-service override
DEFAULT_CPU_LIMIT=1.0
DEFAULT_MEM_LIMIT=512m

# --- Data layer ---
POSTGRES_CPU_LIMIT=2.0
POSTGRES_MEM_LIMIT=1536m

REDIS_CPU_LIMIT=0.5
REDIS_MEM_LIMIT=256m

QDRANT_CPU_LIMIT=1.0
QDRANT_MEM_LIMIT=1024m

NEO4J_CPU_LIMIT=1.0
NEO4J_MEM_LIMIT=1024m

MINIO_CPU_LIMIT=0.5
MINIO_MEM_LIMIT=256m

# --- AI / ML layer ---
OLLAMA_CPU_LIMIT=4.0
OLLAMA_MEM_LIMIT=3072m

EMBEDDING_CPU_LIMIT=2.0
EMBEDDING_MEM_LIMIT=1024m

RERANKER_CPU_LIMIT=1.0
RERANKER_MEM_LIMIT=768m

# --- Document processing ---
DOCLING_CPU_LIMIT=2.0
DOCLING_MEM_LIMIT=1024m

TIKA_CPU_LIMIT=1.0
TIKA_MEM_LIMIT=512m

UNSTRUCTURED_CPU_LIMIT=2.0
UNSTRUCTURED_MEM_LIMIT=1024m

# --- RAG engines ---
LIGHTRAG_CPU_LIMIT=1.0
LIGHTRAG_MEM_LIMIT=512m

MEM0_CPU_LIMIT=1.0
MEM0_MEM_LIMIT=512m

HINDSIGHT_CPU_LIMIT=1.0
HINDSIGHT_MEM_LIMIT=512m

RAGFLOW_CPU_LIMIT=2.0
RAGFLOW_MEM_LIMIT=1536m

# --- Platforms / UIs ---
DIFY_API_CPU_LIMIT=1.5
DIFY_API_MEM_LIMIT=768m

DIFY_WORKER_CPU_LIMIT=1.0
DIFY_WORKER_MEM_LIMIT=512m

DIFY_SANDBOX_CPU_LIMIT=0.5
DIFY_SANDBOX_MEM_LIMIT=256m

DIFY_WEB_CPU_LIMIT=0.5
DIFY_WEB_MEM_LIMIT=256m

OPENWEBUI_CPU_LIMIT=1.0
OPENWEBUI_MEM_LIMIT=512m

OPENWEBUI_PIPELINES_CPU_LIMIT=1.0
OPENWEBUI_PIPELINES_MEM_LIMIT=512m

ANYTHINGLLM_CPU_LIMIT=1.0
ANYTHINGLLM_MEM_LIMIT=512m

# --- Data management ---
NOCODB_CPU_LIMIT=0.5
NOCODB_MEM_LIMIT=256m

DIRECTUS_CPU_LIMIT=0.5
DIRECTUS_MEM_LIMIT=384m

TEABLE_CPU_LIMIT=0.5
TEABLE_MEM_LIMIT=384m

# --- Proxy ---
NPM_CPU_LIMIT=0.5
NPM_MEM_LIMIT=256m

NPM_DB_CPU_LIMIT=0.5
NPM_DB_MEM_LIMIT=256m

# --- Observability / tools ---
LITELLM_CPU_LIMIT=1.0
LITELLM_MEM_LIMIT=512m

LANGFUSE_CPU_LIMIT=1.0
LANGFUSE_MEM_LIMIT=512m

DBHUB_CPU_LIMIT=0.5
DBHUB_MEM_LIMIT=256m


# =============================================================================
# DOCKER IMAGES — March 2026
# =============================================================================
POSTGRES_IMAGE=pgvector/pgvector:pg18
REDIS_IMAGE=valkey/valkey:9.0.3-alpine
QDRANT_IMAGE=qdrant/qdrant:v1.16.3
NEO4J_IMAGE=neo4j:2026.02.3-community
MINIO_IMAGE=pgsty/minio:latest
INFINITY_IMAGE=michaelf34/infinity:latest-cpu
OLLAMA_IMAGE=ollama/ollama:latest
DOCLING_IMAGE=quay.io/ds4sd/docling-serve-cpu:main
TIKA_IMAGE=apache/tika:latest-full
UNSTRUCTURED_IMAGE=quay.io/unstructured-io/unstructured:latest
LIGHTRAG_IMAGE=ghcr.io/hkuds/lightrag:latest
MEM0_IMAGE=mem0/mem0-api-server:latest
HINDSIGHT_IMAGE=ghcr.io/vectorize-io/hindsight:latest
RAGFLOW_IMAGE=infiniflow/ragflow:v0.24.0
INFINITY_DB_IMAGE=infiniflow/infinity:nightly
DIFY_API_IMAGE=langgenius/dify-api:1.13.2
DIFY_WEB_IMAGE=langgenius/dify-web:1.13.2
DIFY_SANDBOX_IMAGE=langgenius/dify-sandbox:0.2.10
OPENWEBUI_IMAGE=ghcr.io/open-webui/open-webui:main
OPENWEBUI_PIPELINES_IMAGE=ghcr.io/open-webui/pipelines:main
ANYTHINGLLM_IMAGE=mintplexlabs/anythingllm:latest
NOCODB_IMAGE=nocodb/nocodb:latest
DIRECTUS_IMAGE=directus/directus:11.16
TEABLE_IMAGE=ghcr.io/teableio/teable:latest
NPM_IMAGE=jc21/nginx-proxy-manager:latest
NPM_DB_IMAGE=jc21/mariadb-aria:latest
LITELLM_IMAGE=ghcr.io/berriai/litellm:main-v1.82.3-stable
LANGFUSE_IMAGE=langfuse/langfuse:3
DBHUB_IMAGE=bytebase/dbhub:latest
